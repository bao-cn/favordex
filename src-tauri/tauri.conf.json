{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fc",
  "version": "0.1.0",
  "identifier": "app.gabriel.fc",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Favordex",
        "label": "main",
        "width": 1600,
        "height": 900,
        "minWidth": 1600,
        "minHeight": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-common"
        ]
      }
    }
  }
}